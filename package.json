{
  "name": "jengkar-ops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check:env": "node scripts/ensure-no-root-env.mjs",
    "env:pull": "npx vercel env pull .env.local --yes",
    "env:pull:development": "npx vercel env pull .env.local --environment=development --yes",
    "env:pull:preview": "npx vercel env pull .env.local --environment=preview --yes",
    "env:pull:production": "npx vercel env pull .env.local --environment=production --yes",
    "deploy:prod": "npm run env:pull:production && npx vercel --prod",
    "predev": "npm run check:env",
    "prebuild": "npm run check:env",
    "pretypecheck": "npm run check:env",
    "predb:generate": "npm run check:env",
    "predb:push": "npm run check:env",
    "predb:seed": "npm run check:env",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "next": "^16.2.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
