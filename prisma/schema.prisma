generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  KARYAWAN
}

enum AttendanceStatus {
  ONTIME
  LATE
  OFF
}

enum StopCardStatus {
  BARU
  DIBACA
  DITINDAKLANJUTI
  SELESAI
}

model User {
  id            String         @id @default(cuid())
  authUserId    String?        @unique @db.Uuid
  name          String
  email         String         @unique
  role          UserRole
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  attendances   Attendance[]
  stopCards     StopCard[]
  dailyProgress DailyProgress[]
  monthlyKpis   KpiMonthly[]
  yearlyKpis    KpiYearly[]
  lockedKpiMonths KpiMonthLock[] @relation("KpiMonthLockedBy")
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model StopCard {
  id        String         @id @default(cuid())
  userId    String
  title     String
  content   String
  status    StopCardStatus @default(BARU)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model DailyProgress {
  id             String   @id @default(cuid())
  pekerjaan      String
  detail         String?
  userId         String
  targetSelesai  DateTime? @db.Date
  tanggalMulai   DateTime? @db.Date
  tanggalSelesai DateTime? @db.Date
  tanggalRevisi  DateTime? @db.Date
  revisiDone     DateTime? @db.Date
  closing        Boolean   @default(false)
  hiddenFromDashboard Boolean @default(false)
  isDone         Boolean   @default(false)
  canceledAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model KpiMonthly {
  id             String   @id @default(cuid())
  userId         String
  year           Int
  month          Int
  scoreKinerja   Float
  scoreDisiplin  Float
  totalScore     Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([year, month])
}

model KpiYearly {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  avgScore  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@index([year])
}

model KpiMonthLock {
  id             String   @id @default(cuid())
  year           Int
  month          Int
  lockedAt       DateTime @default(now())
  lockedByUserId String
  lockedBy       User     @relation("KpiMonthLockedBy", fields: [lockedByUserId], references: [id], onDelete: Cascade)

  @@unique([year, month])
  @@index([lockedAt])
}

model CompanyFinance {
  id        String   @id @default(cuid())
  year      Int      @unique
  netProfit Float
  bonusPool Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
