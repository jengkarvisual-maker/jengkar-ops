generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  KARYAWAN
}

enum AttendanceStatus {
  ONTIME
  LATE
  OFF
}

enum StopCardStatus {
  BARU
  DIBACA
  DITINDAKLANJUTI
  SELESAI
}

enum AddonType {
  TALENT_KONTEN
  MOTRET_TPW
  MOTRET_PHS
  MOTRET_JV
  ASSIST_MAKEUP
  LUAR_KOTA
}

enum WorkdayOverrideType {
  HOLIDAY
  SPECIAL_WORKDAY
}

model User {
  id            String         @id @default(cuid())
  authUserId    String?        @unique @db.Uuid
  name          String
  email         String         @unique
  role          UserRole
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  attendances   Attendance[]
  stopCards     StopCard[]
  hiddenStopCards StopCard[]   @relation("StopCardHiddenByOwner")
  dailyProgress DailyProgress[]
  addons        EmployeeAddon[]
  monthlyKpis   KpiMonthly[]
  yearlyKpis    KpiYearly[]
  lockedKpiMonths KpiMonthLock[] @relation("KpiMonthLockedBy")
  createdWorkdayOverrides WorkdayOverride[] @relation("WorkdayOverrideCreatedBy")
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model StopCard {
  id        String         @id @default(cuid())
  userId    String
  title     String
  content   String
  status    StopCardStatus @default(BARU)
  hiddenFromOwnerDashboard Boolean @default(false)
  hiddenFromOwnerDashboardAt DateTime?
  hiddenFromOwnerDashboardByUserId String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  hiddenFromOwnerDashboardBy User? @relation("StopCardHiddenByOwner", fields: [hiddenFromOwnerDashboardByUserId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([hiddenFromOwnerDashboard, status, createdAt])
}

model DailyProgress {
  id             String   @id @default(cuid())
  pekerjaan      String
  detail         String?
  userId         String
  targetSelesai  DateTime? @db.Date
  tanggalMulai   DateTime? @db.Date
  tanggalSelesai DateTime? @db.Date
  tanggalRevisi  DateTime? @db.Date
  revisiDone     DateTime? @db.Date
  closing        Boolean   @default(false)
  hiddenFromDashboard Boolean @default(false)
  isDone         Boolean   @default(false)
  canceledAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model KpiMonthly {
  id             String   @id @default(cuid())
  userId         String
  year           Int
  month          Int
  scoreKinerja   Float
  scoreDisiplin  Float
  totalScore     Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([year, month])
}

model KpiYearly {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  avgScore  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@index([year])
}

model KpiMonthLock {
  id             String   @id @default(cuid())
  year           Int
  month          Int
  lockedAt       DateTime @default(now())
  lockedByUserId String
  lockedBy       User     @relation("KpiMonthLockedBy", fields: [lockedByUserId], references: [id], onDelete: Cascade)

  @@unique([year, month])
  @@index([lockedAt])
}

model CompanyFinance {
  id        String   @id @default(cuid())
  year      Int      @unique
  netProfit Float
  bonusPool Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeAddon {
  id            String    @id @default(cuid())
  userId        String
  addonDate     DateTime  @db.Date
  addonType     AddonType
  addonQuantity Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([addonDate])
  @@index([userId, addonDate])
}

model WorkdayOverride {
  id              String              @id @default(cuid())
  date            DateTime            @unique @db.Date
  type            WorkdayOverrideType
  label           String
  startTime       String?             @db.VarChar(5)
  endTime         String?             @db.VarChar(5)
  createdByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdBy       User?               @relation("WorkdayOverrideCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([date, type])
}
